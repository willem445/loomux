{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Loomux",
  "version": "0.10.0",
  "identifier": "dev.loomux.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Loomux",
        "width": 1280,
        "height": 800,
        "minWidth": 640,
        "minHeight": 400,
        "backgroundColor": "#131318"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "resources/conhost/*": "./",
      "resources/plugins/resource-monitor/*": "plugins/resource-monitor"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
